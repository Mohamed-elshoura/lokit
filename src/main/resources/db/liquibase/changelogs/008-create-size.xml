<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        https://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.31.xsd">

    <changeSet id="007-create-product-images.xml" author="MohamedElshoura">

        <createTable tableName="sizes">
            <column name="id" type="BIGSERIAL">
                <constraints primaryKey="true" primaryKeyName="pk_sizes" nullable="false"/>
            </column>

            <column name="name" type="VARCHAR(20)">
                <constraints nullable="false" unique="true" uniqueConstraintName="uk_sizes_name"/>
            </column>

        </createTable>
        <rollback>
            <dropTable tableName="sizes"/>
        </rollback>
    </changeSet>
</databaseChangeLog>