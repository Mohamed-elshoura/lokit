<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="
        http://www.liquibase.org/xml/ns/dbchangelog
        https://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="016-create-orders" author="MohamedElshoura">
        <createTable tableName="orders">

            <column name="id" type="BIGSERIAL">
                <constraints primaryKey="true" primaryKeyName="pk_orders" nullable="false"/>
            </column>

            <column name="user_id" type="BIGINT">
                <constraints nullable="false" foreignKeyName="fk_orders_users" references="users(id)"/>
            </column>

            <column name="address_id" type="BIGINT">
                <constraints nullable="false" foreignKeyName="fk_orders_addresses" references="addresses(id)"/>
            </column>

            <column name="status" type="VARCHAR(30)" defaultValue="ORDER_PLACED">
                <constraints nullable="false"/>
            </column>

            <column name="payment_method" type="VARCHAR(30)" defaultValue="CASH">
                <constraints nullable="false"/>
            </column>

            <column name="subtotal" type="DECIMAL(12,2)">
                <constraints nullable="false"/>
            </column>

            <column name="tax" type="DECIMAL(12,2)" defaultValueNumeric="45.00">
                <constraints nullable="false"/>
            </column>

            <column name="shipping" type="DECIMAL(12,2)" defaultValueNumeric="0.00">
                <constraints nullable="false"/>
            </column>

            <column name="total_price" type="DECIMAL(12,2)">
                <constraints nullable="false"/>
            </column>

            <column name="notes" type="VARCHAR(500)"/>

            <column name="created_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>

            <column name="delivered_at" type="TIMESTAMP"/>

            <column name="cancelled_at" type="TIMESTAMP"/>

        </createTable>

        <createIndex tableName="orders" indexName="idx_orders_user_id">
            <column name="user_id"/>
        </createIndex>

        <createIndex tableName="orders" indexName="idx_orders_address_id">
            <column name="address_id"/>
        </createIndex>

        <rollback>
            <dropTable tableName="orders"/>
        </rollback>
    </changeSet>
</databaseChangeLog>